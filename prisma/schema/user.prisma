model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branchId  String?
  roleId    String
  orders    Orders[]
  branch    Branch?  @relation(fields: [branchId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@index([branchId])
}   
